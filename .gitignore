.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.VC.db
*.VC.opendb

# --- Compiler output ---------------------------------------------------------
*.obj
*.pdb
*.ilk
*.lib
*.dll
*.exe
*.exp
*.idb

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo

# --- Windows -----------------------------------------------------------------
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Misc --------------------------------------------------------------------
*.log
*.tmp
*.bak
