            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ninja-gcc-cxx23",
            "configurePreset": "ninja-gcc-cxx23",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ninja-clang",
            "configurePreset": "ninja-clang",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ninja-clang-cxx23",
            "configurePreset": "ninja-clang-cxx23",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
